# Waline 本地服务端口
PORT=8360

# 站点信息（用于通知和后台展示）
SITE_NAME=LycanClaw
SITE_URL=http://localhost:5173

# JWT 密钥（请替换为随机长串）
JWT_TOKEN=replace_with_long_random_secret

# ===== MySQL 配置 =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=waline
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_PREFIX=wl_
MYSQL_CHARSET=utf8mb4

# ===== 安全域名（逗号分隔）=====
# 仅允许这些来源调用 Waline 接口
SECURE_DOMAINS=http://localhost:5173,http://127.0.0.1:5173,https://wreckloud.com,https://www.wreckloud.com,https://lycanclaw.netlify.app

# ===== 登录相关 =====
# 你的旧环境如果支持 QQ 登录，通常是通过 OAuth 服务中转；此处可先沿用默认值
OAUTH_URL=https://oauth.lithub.cc
LOGIN=enable
IPQPS=60

# 是否开启评论审核（true/false）
COMMENT_AUDIT=false

# ===== 可选：管理员通知邮箱 =====
# AUTHOR_EMAIL=your@email.com
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your@email.com
# SMTP_PASS=your_smtp_auth_code
# SMTP_SECURE=true
# SENDER_NAME=LycanClaw
# SENDER_EMAIL=your@email.com
# MAIL_SUBJECT=你在 LycanClaw 的评论有了新回复
# MAIL_TEMPLATE=
# MAIL_SUBJECT_ADMIN=LycanClaw 有新评论
# MAIL_TEMPLATE_ADMIN=
