# Waline 独立运行环境模板（若你不走 compose，可单独使用）
PORT=8360
SITE_NAME=LycanClaw
SITE_URL=https://wreckloud.com
SERVER_URL=https://wreckloud.com/waline
JWT_TOKEN=change-me-waline-jwt-token

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=waline
MYSQL_USER=waline
MYSQL_PASSWORD=change-me-waline-password
MYSQL_PREFIX=wl_
MYSQL_CHARSET=utf8mb4

# 安全域名（逗号分隔）
SECURE_DOMAINS=https://wreckloud.com,https://www.wreckloud.com

# 登录和审核
LOGIN=force
COMMENT_AUDIT=false
OAUTH_URL=https://oauth.lithub.cc
