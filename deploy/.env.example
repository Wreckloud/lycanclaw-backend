# 域名
DOMAIN=wreckloud.com
SITE_NAME=LycanClaw

# MySQL（Waline）
MYSQL_ROOT_PASSWORD=change-me-root-password
WALINE_DB_NAME=waline
WALINE_DB_USER=waline
WALINE_DB_PASSWORD=change-me-waline-password

# Waline
WALINE_JWT_TOKEN=change-me-waline-jwt-token
WALINE_COMMENT_AUDIT=false
WALINE_OAUTH_URL=https://oauth.lithub.cc
# 你的 Waline 管理员邮箱（必须与你登录 Waline 的邮箱一致）
WALINE_OWNER_EMAIL=you@example.com

# 后端管理员令牌（用于 /api/admin/* 与音乐管理接口）
BACKEND_ADMIN_TOKEN=change-me-admin-token

# 宿主机路径（Windows 示例，按你机器实际修改）
BLOG_REPO_HOST_PATH=D:/Portfolio/Website/LycanClaw
POSTS_JSON_HOST_PATH=D:/Portfolio/Website/LycanClaw/docs/public/posts.json
FRONTEND_DIST_HOST_PATH=D:/Portfolio/Website/LycanClaw/docs/.vitepress/dist
