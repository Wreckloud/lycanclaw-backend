# 域名
DOMAIN=wreckloud.com
SITE_NAME=LycanClaw

# MySQL（Waline 与后端统计共享）
MYSQL_ROOT_PASSWORD=change-me-root-password
WALINE_DB_NAME=waline
WALINE_DB_USER=waline
WALINE_DB_PASSWORD=change-me-waline-password

# Waline
WALINE_JWT_TOKEN=change-me-waline-jwt-token
WALINE_COMMENT_AUDIT=false
WALINE_OAUTH_URL=https://oauth.lithub.cc
# 你的 Waline 管理员邮箱（必须与你登录 Waline 的邮箱一致）
WALINE_OWNER_EMAIL=you@example.com
WALINE_SMTP_HOST=smtp.qq.com
WALINE_SMTP_SERVICE=
WALINE_SMTP_PORT=465
WALINE_SMTP_SECURE=true
WALINE_SMTP_USER=you@example.com
WALINE_SMTP_PASS=change-me-smtp-auth-code
WALINE_AUTHOR_EMAIL=you@example.com
WALINE_SENDER_NAME=LycanClaw
WALINE_SENDER_EMAIL=you@example.com
WALINE_DISABLE_AUTHOR_NOTIFY=false
# 可选：Waline 邮件模板。留空则使用 Waline 默认模板。
WALINE_MAIL_SUBJECT=你在 LycanClaw 的评论有了新回复
WALINE_MAIL_TEMPLATE=
WALINE_MAIL_SUBJECT_ADMIN=LycanClaw 有新评论
WALINE_MAIL_TEMPLATE_ADMIN=

# 后端管理员令牌（用于 /api/admin/* 与音乐管理接口）
BACKEND_ADMIN_TOKEN=change-me-admin-token

# 宿主机路径（Windows 示例，按你机器实际修改）
BLOG_REPO_HOST_PATH=D:/Portfolio/Website/LycanClaw/frontend
POSTS_JSON_HOST_PATH=D:/Portfolio/Website/LycanClaw/frontend/docs/public/posts.json
FRONTEND_DIST_HOST_PATH=D:/Portfolio/Website/LycanClaw/frontend/docs/.vitepress/dist
IP2REGION_V4_XDB_HOST_PATH=D:/data/ip2region_v4.xdb
IP2REGION_V6_XDB_HOST_PATH=D:/data/ip2region_v6.xdb
