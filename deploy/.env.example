DOMAIN=wreckloud.com
SITE_NAME=LycanClaw
MUSIC_RANKING_OWNER_UID=
MUSIC_PREFERRED_LEVEL=exhigh
RECOMMENDATION_MAX_CANDIDATE_POSTS=200
RECOMMENDATION_PAGEVIEW_WEIGHT=1.0
RECOMMENDATION_COMMENT_WEIGHT=24.0

# MySQL（Waline 与后端共享数据库实例）
MYSQL_ROOT_PASSWORD=change-me-root-password
WALINE_DB_NAME=waline
WALINE_DB_USER=waline
WALINE_DB_PASSWORD=change-me-waline-password

# Waline
WALINE_JWT_TOKEN=change-me-waline-jwt-token
WALINE_COMMENT_AUDIT=false
WALINE_OAUTH_URL=https://oauth.lithub.cc
WALINE_SMTP_HOST=smtp.qq.com
WALINE_SMTP_SERVICE=
WALINE_SMTP_PORT=465
WALINE_SMTP_SECURE=true
WALINE_SMTP_USER=you@example.com
WALINE_SMTP_PASS=change-me-smtp-auth-code
WALINE_AUTHOR_EMAIL=you@example.com
WALINE_SENDER_NAME=LycanClaw
WALINE_SENDER_EMAIL=you@example.com
WALINE_MAIL_SUBJECT=你在 LycanClaw 的评论有了新回复
WALINE_MAIL_TEMPLATE=
WALINE_MAIL_SUBJECT_ADMIN=LycanClaw 有新评论
WALINE_MAIL_TEMPLATE_ADMIN=

# 后端应急管理员令牌。日常管理使用 Waline 登录会话。
BACKEND_ADMIN_TOKEN=
BACKEND_ADMIN_QQ_WHITELIST=your-qq-id

# GitHub Actions 同步 posts.json 与 knowledge-stats.json 的稳定目录
CONTENT_DATA_HOST_PATH=/srv/lycanclaw/shared

# 后台访问统计排除的访客昵称，通常填站长 Waline 昵称。
LYCAN_ANALYTICS_EXCLUDED_VISITOR_NAMES=
# 后台访问统计排除的 Waline 用户 ID，通常无需填写；昵称不稳定时再填。
LYCAN_ANALYTICS_EXCLUDED_WALINE_USER_IDS=

# IP 地区库。执行 deploy/scripts/install-ip2region.sh 后自动准备文件。
LYCAN_IP2REGION_V4_XDB_PATH=/data/ip2region/ip2region_v4.xdb
LYCAN_IP2REGION_V6_XDB_PATH=
