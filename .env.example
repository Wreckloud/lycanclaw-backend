# Spring Boot 本地/服务器运行环境变量模板

# 服务端口
SERVER_PORT=8080

# MySQL
LYCAN_DB_URL=jdbc:mysql://127.0.0.1:3306/lycanclaw_local_test?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
LYCAN_DB_USERNAME=root
LYCAN_DB_PASSWORD=

# 允许跨域来源（逗号分隔）
LYCAN_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://wreckloud.com,https://www.wreckloud.com

# 管理员令牌（务必替换）
LYCAN_SECURITY_ADMIN_TOKEN=

# 前端生成的内容索引
LYCAN_CONTENT_POSTS_JSON_PATH=../frontend/docs/public/posts.json
LYCAN_CONTENT_KNOWLEDGE_STATS_JSON_PATH=../frontend/docs/public/knowledge-stats.json

# 网易云上游 API（neteasecloudmusicapienhanced）
LYCAN_MUSIC_UPSTREAM_BASE_URL=http://127.0.0.1:3000
LYCAN_MUSIC_RANKING_OWNER_UID=
LYCAN_MUSIC_PREFERRED_LEVEL=exhigh

# Waline 聚合入口
LYCAN_WALINE_BASE_URL=http://127.0.0.1:8360

# 推荐与文章指标运维配置
LYCAN_RECOMMENDATION_MAX_CANDIDATE_POSTS=200
LYCAN_RECOMMENDATION_PAGEVIEW_WEIGHT=1.0
LYCAN_RECOMMENDATION_COMMENT_WEIGHT=24.0
LYCAN_ARTICLE_METRICS_SYNC_INTERVAL_MILLIS=600000
LYCAN_ARTICLE_METRICS_FETCH_PARALLELISM=6
LYCAN_ARTICLE_METRICS_FETCH_TIMEOUT_SECONDS=15
LYCAN_ARTICLE_METRICS_STARTUP_SYNC_ENABLED=true
