# Spring Boot 本地/服务器运行环境变量模板

# 服务端口
SERVER_PORT=8080

# MySQL（推荐聚合落库）
LYCAN_DB_URL=jdbc:mysql://127.0.0.1:3306/lycanclaw_local_test?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
LYCAN_DB_USERNAME=root
LYCAN_DB_PASSWORD=

# 允许跨域来源（逗号分隔）
LYCAN_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://wreckloud.com,https://www.wreckloud.com

# 管理员令牌（务必替换）
LYCAN_SECURITY_ADMIN_TOKEN=change-me-admin-token

# 热力图统计范围
LYCAN_ANALYTICS_REPO_PATH=D:/Portfolio/Website/LycanClaw/frontend
LYCAN_ANALYTICS_KNOWLEDGE_STATS_JSON_PATH=D:/Portfolio/Website/LycanClaw/frontend/docs/public/knowledge-stats.json
LYCAN_ANALYTICS_SCOPE=docs/thoughts,docs/knowledge
LYCAN_ANALYTICS_DAYS=365
LYCAN_ANALYTICS_ZONE_ID=Asia/Shanghai

# 网易云上游 API（neteasecloudmusicapienhanced）
LYCAN_MUSIC_UPSTREAM_BASE_URL=http://127.0.0.1:3000
LYCAN_MUSIC_PLAYLIST_OWNER_UID=629126546
LYCAN_MUSIC_PREFERRED_LEVEL=exhigh

# Waline 聚合入口
LYCAN_WALINE_BASE_URL=http://127.0.0.1:8360

# 内容索引（推荐/标签）
LYCAN_RECOMMENDATION_POSTS_JSON_PATH=D:/Portfolio/Website/LycanClaw/frontend/docs/public/posts.json
LYCAN_RECOMMENDATION_MANUAL_CONFIG_PATH=data/recommendation-manual.json
LYCAN_RECOMMENDATION_AGGREGATION_INTERVAL_MILLIS=300000
LYCAN_RECOMMENDATION_AGGREGATION_FETCH_PARALLELISM=6
LYCAN_RECOMMENDATION_AGGREGATION_FETCH_TIMEOUT_SECONDS=15
LYCAN_RECOMMENDATION_SNAPSHOT_FRESH_SECONDS=900
LYCAN_RECOMMENDATION_STARTUP_WARMUP_ENABLED=true
LYCAN_TAG_POSTS_JSON_PATH=D:/Portfolio/Website/LycanClaw/frontend/docs/public/posts.json
